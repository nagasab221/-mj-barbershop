# Copy this file to .env.local and fill in the values.
# On Cloudflare Pages, set the same variables in the project's Settings →
# Environment variables (NEXT_PUBLIC_* ones must be present at build time).

# Supabase — create a free project at https://supabase.com/dashboard,
# run supabase/schema.sql in the SQL Editor, then copy these from
# Project Settings → API. The service_role key is server-side only.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Password for the /admin dashboard.
ADMIN_PASSWORD=""
# Long random string that signs the admin session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=""

# Telegram bot for reservation notifications.
# Create a bot with @BotFather, then get your chat id from @userinfobot.
# IMPORTANT: open your bot in Telegram and press Start once, or it cannot message you.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Public URL of the deployed site (used for SEO metadata / sitemap).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
